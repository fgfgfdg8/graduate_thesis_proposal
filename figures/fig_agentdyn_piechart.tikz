% AgentDyn数据集分布图：上方三张饼图，下方柱状图
% 场景：Shopping 180对(32.1%) / GitHub 180对(32.1%) / Daily Life 200对(35.7%)
% 攻击类型：important_instructions与none（注入嵌入邮件、评论、通知等）
% 工具数：Shopping 7工具 / GitHub 7工具 / Daily Life 7工具
% 下方：8个主流模型ASR分布条形图
\begin{tikzpicture}[x=1cm, y=1cm]

\def\pieR{1.75}
\def\legendFont{\scriptsize}
\def\titleFont{\scriptsize\bfseries}
\def\percentFont{\scriptsize\bfseries}

% ===== 上：三张饼图 =====
\node[font=\footnotesize\bfseries, anchor=center] at (7.0,7.0) {AgentDyn数据集场景分布、攻击向量类型与防御覆盖};

% --- 饼图1：各场景测试对占比 ---
\def\cx{2.2}
\def\cy{3.85}
% Shopping: 180/560=32.1% => 90° to -25.7° (115.7°)
% GitHub: 180/560=32.1% => -25.7° to -141.4° (115.7°)
% Daily Life: 200/560=35.7% => -141.4° to -270° (128.6°)
\fill[pieBlue!80] (\cx,\cy) -- ++(90:\pieR) arc[start angle=90, end angle=-25.7, radius=\pieR] -- cycle;
\fill[pieGreen!80] (\cx,\cy) -- ++(-25.7:\pieR) arc[start angle=-25.7, end angle=-141.4, radius=\pieR] -- cycle;
\fill[pieOrange!80] (\cx,\cy) -- ++(-141.4:\pieR) arc[start angle=-141.4, end angle=-270, radius=\pieR] -- cycle;
\foreach \a in {90,-25.7,-141.4} {
  \draw[white, line width=0.9pt] (\cx,\cy) -- ++(\a:\pieR);
}
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(32.15)}, {\cy + 1.00*sin(32.15)}) {32.1\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-83.55)}, {\cy + 1.00*sin(-83.55)}) {32.1\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-205.7)}, {\cy + 1.00*sin(-205.7)}) {35.7\%};
\node[font=\titleFont] at (\cx,6.0) {场景测试对};
\fill[pieBlue!80]   (0.15,1.55) rectangle (0.40,1.75); \node[font=\legendFont, anchor=west] at (0.47,1.65) {Shopping 180};
\fill[pieGreen!80]  (0.15,1.20) rectangle (0.40,1.40); \node[font=\legendFont, anchor=west] at (0.47,1.30) {GitHub 180};
\fill[pieOrange!80] (2.70,1.55) rectangle (2.95,1.75); \node[font=\legendFont, anchor=west] at (3.02,1.65) {Daily Life 200};

% --- 饼图2：工具数量分布 ---
\def\cx{7.0}
\def\cy{3.85}
% Shopping: email/bank/file/web/calendar/shopping/github = 7
% GitHub: email/bank/file/web/calendar/shopping/github = 7
% Daily Life: email/bank/file/web/calendar/shopping/github = 7
% Actually each suite uses different subsets. Let's show tools per suite
% Common tools across suites
% All 3 suites share the same 7 tool types: email, bank, filesystem, web, calendar, shopping_platform, github_platform
% Each suite has 7 tools
\fill[pieBlue!80] (\cx,\cy) -- ++(90:\pieR) arc[start angle=90, end angle=-30, radius=\pieR] -- cycle;
\fill[pieGreen!80] (\cx,\cy) -- ++(-30:\pieR) arc[start angle=-30, end angle=-150, radius=\pieR] -- cycle;
\fill[pieOrange!80] (\cx,\cy) -- ++(-150:\pieR) arc[start angle=-150, end angle=-270, radius=\pieR] -- cycle;
\foreach \a in {90,-30,-150} {
  \draw[white, line width=0.9pt] (\cx,\cy) -- ++(\a:\pieR);
}
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(30)}, {\cy + 1.00*sin(30)}) {33.3\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-90)}, {\cy + 1.00*sin(-90)}) {33.3\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-210)}, {\cy + 1.00*sin(-210)}) {33.3\%};
\node[font=\titleFont] at (\cx,6.0) {各场景工具数};
\fill[pieBlue!80]   (5.10,1.55) rectangle (5.35,1.75); \node[font=\legendFont, anchor=west] at (5.42,1.65) {Shopping 7};
\fill[pieGreen!80]  (5.10,1.20) rectangle (5.35,1.40); \node[font=\legendFont, anchor=west] at (5.42,1.30) {GitHub 7};
\fill[pieOrange!80] (7.55,1.55) rectangle (7.80,1.75); \node[font=\legendFont, anchor=west] at (7.87,1.65) {Daily Life 7};

% --- 饼图3：攻击注入向量 ---
\def\cx{12.0}
\def\cy{3.85}
% Injection vectors: email, reviews, notifications, file contents, web content, etc.
% Simplified as: email-based (40%), review/comment-based (30%), other notification-based (30%)
\fill[pieRed!80] (\cx,\cy) -- ++(90:\pieR) arc[start angle=90, end angle=-54, radius=\pieR] -- cycle;
\fill[pieBlue!80] (\cx,\cy) -- ++(-54:\pieR) arc[start angle=-54, end angle=-162, radius=\pieR] -- cycle;
\fill[pieTeal!80] (\cx,\cy) -- ++(-162:\pieR) arc[start angle=-162, end angle=-270, radius=\pieR] -- cycle;
\foreach \a in {90,-54,-162} {
  \draw[white, line width=0.9pt] (\cx,\cy) -- ++(\a:\pieR);
}
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(18)}, {\cy + 1.00*sin(18)}) {40\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-108)}, {\cy + 1.00*sin(-108)}) {30\%};
\node[font=\percentFont, text=white] at ({\cx + 1.00*cos(-216)}, {\cy + 1.00*sin(-216)}) {30\%};
\node[font=\titleFont] at (\cx,6.0) {注入向量类型};
\fill[pieRed!80]  (10.15,1.55) rectangle (10.40,1.75); \node[font=\legendFont, anchor=west] at (10.47,1.65) {邮件注入};
\fill[pieBlue!80] (10.15,1.20) rectangle (10.40,1.40); \node[font=\legendFont, anchor=west] at (10.47,1.30) {评论/内容注入};
\fill[pieTeal!80] (12.15,1.55) rectangle (12.40,1.75); \node[font=\legendFont, anchor=west] at (12.47,1.65) {通知注入};

% ===== 下：柱状图 =====
\node[font=\footnotesize\bfseries, anchor=center] at (7.0,0.35) {AgentDyn 8个主流模型无防御攻击成功率（ASR）分布};
\def\bx{0.8}
\def\by{-5.8}
\def\bh{5.0}
\draw[->, line width=0.8pt, agentGray] (\bx,\by) -- (\bx,{\by+\bh+0.6});
\draw[->, line width=0.8pt, agentGray] (\bx,\by) -- ({\bx+12.0},\by);
\foreach \v/\lbl in {0/0, 1.25/25, 2.5/50, 3.75/75, 5.0/100} {
  \draw[agentGray, line width=0.35pt, dashed] (\bx,{\by+\v}) -- ({\bx+11.6},{\by+\v});
  \node[font=\tiny, anchor=east, text=agentGray] at ({\bx-0.10},{\by+\v}) {\lbl};
}
\node[font=\scriptsize, rotate=90, anchor=south, text=agentGray] at ({\bx-0.65},{\by+\bh/2}) {ASR (\%)};

% 50%参考线
\draw[pieRed, line width=0.7pt, dashed] (\bx,{\by+2.5}) -- ({\bx+11.6},{\by+2.5});
\node[font=\tiny, text=pieRed, anchor=west] at ({\bx+11.6},{\by+2.5}) {50\%};

\def\bw{0.82}
\def\bs{1.35}

% Models sorted by ASR (ascending)
% GPT-4o-mini: 48.9
\fill[pieOrange!80] ({\bx+0*\bs+0.20}, \by) rectangle ({\bx+0*\bs+0.20+\bw}, {\by+48.9/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+0*\bs+0.20+\bw/2}, {\by-0.15}) {4o-mini};
\node[font=\tiny\bfseries, text=pieOrange] at ({\bx+0*\bs+0.20+\bw/2}, {\by+48.9/100*\bh+0.22}) {48.9\%};

% GPT-4o: 61.1
\fill[pieRed!80] ({\bx+1*\bs+0.20}, \by) rectangle ({\bx+1*\bs+0.20+\bw}, {\by+61.1/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+1*\bs+0.20+\bw/2}, {\by-0.15}) {GPT-4o};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+1*\bs+0.20+\bw/2}, {\by+61.1/100*\bh+0.22}) {61.1\%};

% Gemini-2.5-Pro: 78.2
\fill[pieRed!80] ({\bx+2*\bs+0.20}, \by) rectangle ({\bx+2*\bs+0.20+\bw}, {\by+78.2/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+2*\bs+0.20+\bw/2}, {\by-0.15}) {Gem2.5-Pro};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+2*\bs+0.20+\bw/2}, {\by+78.2/100*\bh+0.22}) {78.2\%};

% Qwen3-235B: 85.4
\fill[pieRed!80] ({\bx+3*\bs+0.20}, \by) rectangle ({\bx+3*\bs+0.20+\bw}, {\by+85.4/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+3*\bs+0.20+\bw/2}, {\by-0.15}) {Qwen3-235B};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+3*\bs+0.20+\bw/2}, {\by+85.4/100*\bh+0.22}) {85.4\%};

% Gemini-2.5-Flash: 85.9
\fill[pieRed!80] ({\bx+4*\bs+0.20}, \by) rectangle ({\bx+4*\bs+0.20+\bw}, {\by+85.9/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+4*\bs+0.20+\bw/2}, {\by-0.15}) {Gem2.5-Flash};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+4*\bs+0.20+\bw/2}, {\by+85.9/100*\bh+0.22}) {85.9\%};

% Llama-3.3-70B: 87.5
\fill[pieRed!80] ({\bx+5*\bs+0.20}, \by) rectangle ({\bx+5*\bs+0.20+\bw}, {\by+87.5/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+5*\bs+0.20+\bw/2}, {\by-0.15}) {Llama3.3-70B};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+5*\bs+0.20+\bw/2}, {\by+87.5/100*\bh+0.22}) {87.5\%};

% GPT-5.1: 96.1
\fill[pieRed!80] ({\bx+6*\bs+0.20}, \by) rectangle ({\bx+6*\bs+0.20+\bw}, {\by+96.1/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+6*\bs+0.20+\bw/2}, {\by-0.15}) {GPT-5.1};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+6*\bs+0.20+\bw/2}, {\by+96.1/100*\bh+0.22}) {96.1\%};

% GPT-5-mini: 99.6
\fill[pieRed!80] ({\bx+7*\bs+0.20}, \by) rectangle ({\bx+7*\bs+0.20+\bw}, {\by+99.6/100*\bh});
\node[font=\tiny, rotate=60, anchor=east] at ({\bx+7*\bs+0.20+\bw/2}, {\by-0.15}) {GPT-5-mini};
\node[font=\tiny\bfseries, text=pieRed] at ({\bx+7*\bs+0.20+\bw/2}, {\by+99.6/100*\bh+0.22}) {99.6\%};

% 颜色图例
\fill[pieOrange!80] (0.40,{\by-2.18}) rectangle (0.80,{\by-1.88}); \node[font=\tiny, anchor=west] at (0.95,{\by-2.03}) {中风险（25\%$\leq$ASR$<$50\%）};
\fill[pieRed!80]    (5.50,{\by-2.18}) rectangle (5.90,{\by-1.88}); \node[font=\tiny, anchor=west] at (6.05,{\by-2.03}) {高风险（ASR$\geq$50\%）};

\end{tikzpicture}
